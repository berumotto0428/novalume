# ── LLM（大语言模型） ──
# DeepSeek API，使用 OpenAI 兼容接口
LLM_API_KEY=your_deepseek_api_key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3

# ── Embedding（文本向量化） ──
# 智谱 AI embedding-3
EMBEDDING_API_KEY=your_zhipu_api_key
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_MODEL=embedding-3

# 视觉模型（用于理解图片、扫描版PDF、含图PPT）
# 使用通义千问 Qwen-VL-Flash，留空则跳过图片处理
VISION_API_KEY=
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen3.6-plus

# ── JWT ──
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_random_secret_key

# ── 文档处理与检索 ──
MAX_UPLOAD_SIZE_MB=50      # 单个上传文件大小上限（MB）
CHUNK_SIZE=1000             # PDF 文本分块大小（字符数）
CHUNK_OVERLAP=200          # 相邻块重叠字符数
RRF_K=40                   # RRF 常数（分母中的 K，越大排名差异对分数的影响越小）
KEYWORD_WEIGHT=0.4         # 关键词权重（0~1，0=纯语义，0.5=等权重，1=纯关键词）
FETCH_COUNT=30             # 从向量库一次性取多少个候选（阈值过滤后会进一步缩减）
MAX_CHUNKS=15             # 最终传给 LLM 的最大片段数（不超过阈值就少取，动态决定）
TOP_K_MAX_DISTANCE=0.65    # 余弦距离阈值，超过此值的片段丢弃

# ── 前端地址（CORS） ──
CORS_ORIGINS=["http://localhost:5173","http://localhost"]
